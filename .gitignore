# Secrets / environment
.env
.env.*
!*.env.example

# Storage dirs (logs, cache, compiled views, symlinks)
**/storage/
**/shared-storage/
**/public/storage

# Build artifacts (compiled JS/CSS)
**/public/build/assets/

# SSL / certbot accounts and private keys
**/certs/accounts/
**/certs/archive/*/privkey*.pem
**/certs/live/*/privkey.pem
**/certs/.gitkeep

# ACME challenge files
**/certbot-www/

# Old proxy directory (duplicate of _proxy)
/proxy/

# Logs
*.log

# Backup files (all variants — .bak, .bak-<suffix>, .yml.bak-<suffix>, etc.)
*.bak
*.bak-*
*.swp

# Database backups — never commit dumps to a public repo
backups/*.sql
backups/*.sql.gz
backups/*.json

# macOS artifacts
.DS_Store
._*

# Temp files
*.tmp

# Deploy artifacts
last_deploy_sha
active
active_color
