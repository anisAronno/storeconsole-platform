# Server + alert metadata
SERVER_NAME=storeconsole-vps
SERVER_IP=135.125.131.135

# GHCR
GHCR_USERNAME=anisaronno
GHCR_TOKEN=SET_GHCR_TOKEN

# Brevo alert channel
ALERT_TO_EMAIL=hello@anichur.com
ALERT_FROM_EMAIL=alerts@example.com
ALERT_FROM_NAME="Store Console Server"
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USERNAME=SET_BREVO_SMTP_USERNAME
BREVO_SMTP_PASSWORD=SET_BREVO_SMTP_PASSWORD

# Basic auth (dev/staging/monitor)
DEV_BASIC_AUTH_USER=devadmin
DEV_BASIC_AUTH_PASS=SET_DEV_BASIC_AUTH_PASS
STAGING_BASIC_AUTH_USER=stagingadmin
STAGING_BASIC_AUTH_PASS=SET_STAGING_BASIC_AUTH_PASS
MONITOR_BASIC_AUTH_USER=monitoradmin
MONITOR_BASIC_AUTH_PASS=SET_MONITOR_BASIC_AUTH_PASS

# Postgres superuser
POSTGRES_IMAGE=pgvector/pgvector:pg18-trixie
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERPASS=SET_POSTGRES_SUPERPASS
POSTGRES_SUPERDB=postgres

# Application/pulse databases and users
STORECONSOLE_PROD_DB=storeconsole_production
STORECONSOLE_STAGING_DB=storeconsole_staging
STORECONSOLE_DEV_DB=storeconsole_dev
PULSE_PROD_DB=pulse_production
PULSE_STAGING_DB=pulse_staging
PULSE_DEV_DB=pulse_dev

STORECONSOLE_PROD_USER=storeconsole_prod_user
STORECONSOLE_STAGING_USER=storeconsole_staging_user
STORECONSOLE_DEV_USER=storeconsole_dev_user
PULSE_PROD_USER=pulse_prod_user
PULSE_STAGING_USER=pulse_staging_user
PULSE_DEV_USER=pulse_dev_user

STORECONSOLE_PROD_PASSWORD=SET_STORECONSOLE_PROD_PASSWORD
STORECONSOLE_STAGING_PASSWORD=SET_STORECONSOLE_STAGING_PASSWORD
STORECONSOLE_DEV_PASSWORD=SET_STORECONSOLE_DEV_PASSWORD
PULSE_PROD_PASSWORD=SET_PULSE_PROD_PASSWORD
PULSE_STAGING_PASSWORD=SET_PULSE_STAGING_PASSWORD
PULSE_DEV_PASSWORD=SET_PULSE_DEV_PASSWORD

# Redis
REDIS_PASSWORD=SET_REDIS_PASSWORD

# Beszel
BESZEL_APP_URL=https://monitor.storeconsole.com
BESZEL_AGENT_KEY=SET_BESZEL_AGENT_KEY
BESZEL_AGENT_TOKEN=SET_BESZEL_AGENT_TOKEN

# Central Reverb
STORECONSOLE_REVERB_IMAGE=ghcr.io/anisaronno/storeconsole:latest-production
REVERB_ENABLED=true
REVERB_APP_ALLOWED_ORIGINS=https://storeconsole.com,https://staging.storeconsole.com,https://dev.storeconsole.com
REVERB_APP_RATE_LIMITING_ENABLED=true
REVERB_APP_RATE_LIMIT_MAX_ATTEMPTS=120
REVERB_APP_RATE_LIMIT_DECAY_SECONDS=60
REVERB_SCALING_ENABLED=true

# Cloudflare R2 backups
R2_ENABLED=false
R2_ACCOUNT_ID=478b155312ae834cae9480ee13bd1401
R2_ENDPOINT=https://478b155312ae834cae9480ee13bd1401.r2.cloudflarestorage.com
R2_BUCKET=storeconsole
R2_PUBLIC_URL=https://pub-6a02698b7175423dbf947f5e0b65f22b.r2.dev
R2_PREFIX=storeconsole.com
R2_ACCESS_KEY_ID=SET_R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=SET_R2_SECRET_ACCESS_KEY
R2_STRICT_MODE=false
BACKUP_RETENTION_DAYS=40
BACKUP_PURGE_LOCAL_AFTER_UPLOAD=true

# AI providers copied into each app env by render-secrets.sh
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_FOR_EMBEDDINGS=openai
OPENAI_API_KEY=SET_OPENAI_API_KEY
ANTHROPIC_API_KEY=SET_ANTHROPIC_API_KEY
GEMINI_API_KEY=SET_GEMINI_API_KEY
VOYAGEAI_API_KEY=SET_VOYAGEAI_API_KEY
