APP_NAME="Store Console"
APP_ENV=demo
APP_DEBUG=false
APP_URL=https://demo.storeconsole.com
SSR_ENABLED=false
INERTIA_SSR_THROW_ON_ERROR=false
APP_TIMEZONE=UTC
APP_KEY=<SET_FROM_ARTISAN_KEY_GENERATE>

APP_IMAGE=ghcr.io/anisaronno/storeconsole:latest-demo

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=pgbouncer
DB_PORT=5432
DB_DATABASE=storeconsole_demo
DB_USERNAME=storeconsole_demo_user
DB_PASSWORD=<STORECONSOLE_DEMO_PASSWORD>
DB_EMULATE_PREPARES=true

PULSE_ENABLED=false
PULSE_DB_CONNECTION=pulse
DB_PULSE_CONNECTION=pgsql
PULSE_INGEST_DRIVER=redis
PULSE_INGEST_REDIS_CONNECTION=default

DB_PULSE_HOST=pgbouncer
DB_PULSE_PORT=5432
DB_PULSE_DATABASE=pulse_demo
DB_PULSE_USERNAME=pulse_demo_user
DB_PULSE_PASSWORD=<PULSE_DEMO_PASSWORD>

CACHE_STORE=redis
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_REDIS_CONNECTION=sessions

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<REDIS_PASSWORD>
REDIS_DB=8
REDIS_CACHE_DB=9
REDIS_SESSION_DB=10
REDIS_QUEUE_DB=11
REDIS_QUEUE_CONNECTION=queue
REDIS_PREFIX=storeconsole_demo

BROADCAST_CONNECTION=reverb
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_HOST=storeconsole-reverb
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_APP_ID=<REVERB_APP_ID>
REVERB_APP_KEY=<REVERB_APP_KEY>
REVERB_APP_SECRET=<REVERB_APP_SECRET>
VITE_REVERB_APP_KEY=<REVERB_APP_KEY>
VITE_REVERB_HOST=demo.storeconsole.com
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
REVERB_APP_ALLOWED_ORIGINS=https://storeconsole.com,https://staging.storeconsole.com,https://dev.storeconsole.com,https://demo.storeconsole.com
REVERB_APP_RATE_LIMITING_ENABLED=true
REVERB_APP_RATE_LIMIT_MAX_ATTEMPTS=120
REVERB_APP_RATE_LIMIT_DECAY_SECONDS=60
REVERB_SCALING_ENABLED=true

MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=<BREVO_SMTP_USERNAME>
MAIL_PASSWORD=<BREVO_SMTP_PASSWORD>
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=<VERIFIED_BREVO_SENDER>
MAIL_FROM_NAME="Store Console"

ALERT_TO_EMAIL=hello@anichur.com
ALERT_FROM_EMAIL=<VERIFIED_BREVO_SENDER>
ALERT_FROM_NAME="Store Console Server"

OCTANE_SERVER=frankenphp
OCTANE_HTTPS=false
OCTANE_MAX_REQUESTS=500
OCTANE_WORKERS=1
OCTANE_TASK_WORKERS=1

# Real, live connection to production's license authority — this is what makes
# demo.storeconsole.com show a genuinely licensed, all-modules-unlocked
# customer instance rather than locally-faked data. See Launcher module.
LICENSE_SERVER_URL=https://storeconsole.com
LICENSE_GRACE_PERIOD_DAYS=30
LICENSE_REFRESH_SCHEDULE=03:15
