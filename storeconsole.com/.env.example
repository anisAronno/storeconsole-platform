APP_NAME="Store Console"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://storeconsole.com
SSR_ENABLED=true
SSR_URL=http://storeconsole-production-ssr:13714
INERTIA_SSR_THROW_ON_ERROR=false
APP_TIMEZONE=UTC
APP_KEY=<SET_FROM_ARTISAN_KEY_GENERATE>

APP_IMAGE=ghcr.io/anisaronno/storeconsole:latest-production

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=pgsql
DB_HOST=pgbouncer
DB_PORT=5432
DB_DATABASE=storeconsole_production
DB_USERNAME=storeconsole_prod_user
DB_PASSWORD=<STORECONSOLE_PROD_PASSWORD>
DB_EMULATE_PREPARES=true

PULSE_ENABLED=true
PULSE_DB_CONNECTION=pulse
DB_PULSE_CONNECTION=pgsql
PULSE_INGEST_DRIVER=redis
PULSE_INGEST_REDIS_CONNECTION=default

DB_PULSE_HOST=pgbouncer
DB_PULSE_PORT=5432
DB_PULSE_DATABASE=pulse_production
DB_PULSE_USERNAME=pulse_prod_user
DB_PULSE_PASSWORD=<PULSE_PROD_PASSWORD>

CACHE_STORE=redis
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_REDIS_CONNECTION=sessions

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=<REDIS_PASSWORD>
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3
REDIS_QUEUE_CONNECTION=queue
REDIS_PREFIX=storeconsole_prod

BROADCAST_CONNECTION=reverb
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_HOST=storeconsole-reverb
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_APP_ID=<REVERB_APP_ID>
REVERB_APP_KEY=<REVERB_APP_KEY>
REVERB_APP_SECRET=<REVERB_APP_SECRET>
VITE_REVERB_APP_KEY=<REVERB_APP_KEY>
VITE_REVERB_HOST=storeconsole.com
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https
REVERB_APP_ALLOWED_ORIGINS=https://storeconsole.com,https://staging.storeconsole.com,https://dev.storeconsole.com
REVERB_APP_RATE_LIMITING_ENABLED=true
REVERB_APP_RATE_LIMIT_MAX_ATTEMPTS=120
REVERB_APP_RATE_LIMIT_DECAY_SECONDS=60
REVERB_SCALING_ENABLED=true

MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=<BREVO_SMTP_USERNAME>
MAIL_PASSWORD=<BREVO_SMTP_PASSWORD>
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=<VERIFIED_BREVO_SENDER>
MAIL_FROM_NAME="Store Console"

ALERT_TO_EMAIL=hello@anichur.com
ALERT_FROM_EMAIL=<VERIFIED_BREVO_SENDER>
ALERT_FROM_NAME="Store Console Server"

OCTANE_SERVER=frankenphp
OCTANE_HTTPS=false
OCTANE_MAX_REQUESTS=500
OCTANE_WORKERS=2
OCTANE_TASK_WORKERS=2

AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_FOR_EMBEDDINGS=openai
OPENAI_API_KEY=<OPENAI_API_KEY>
ANTHROPIC_API_KEY=<ANTHROPIC_API_KEY>
GEMINI_API_KEY=<GEMINI_API_KEY>
VOYAGEAI_API_KEY=<VOYAGEAI_API_KEY>
